# All settings have sensible defaults for local development.
# Copy to .env only if you need to override defaults.

# Database connection (default works with docker-compose.yaml)
# DB_DSN=postgres://bytebattle:bytebattle@localhost:5432/bytebattle?sslmode=disable

# HTTP server
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080

# Email verification (Resend)
# If RESEND_API_KEY is empty, app falls back to dev mailer and logs the code.
# RESEND_API_KEY=re_...
# FROM_EMAIL=Byte Battle <noreply@yourdomain.com>

# CORS + WebSocket origin restriction (empty = allow all, set in prod to your domain)
# Comma-separated list of allowed origins, e.g.: https://bytebattle.dev,https://www.bytebattle.dev
# ALLOWED_ORIGINS=https://yourdomain.com

# Production only (used by docker-compose.prod.yaml)
# HTTP_RATE_PER_MINUTE=100                  # IP-based rate limit (req/min), 0 = disabled; default 100 in prod
# DB_USER=bytebattle
# DB_PASSWORD=<secure-password>
# DB_NAME=bytebattle
# HTTP_PORT=80
# IMAGE=ghcr.io/owner/byte-battle
# ALLOWED_ORIGINS=https://yourdomain.com
# DEPLOY_UID=1001                            # deploy user UID: run `id -u` on VPS to get it
# DOCKER_SOCKET=/run/user/1001/docker.sock  # rootless Docker socket path (same UID)

# GitHub Actions secrets (set in repo Settings → Secrets, not in .env):
#   SSH_HOST        — VPS IP address
#   SSH_USER        — VPS SSH username
#   SSH_PRIVATE_KEY — private key for SSH access
#   CR_PAT          — GitHub Personal Access Token with packages:read scope (for docker pull on VPS)
